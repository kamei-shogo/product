{
  "manifest_version": 3,
  "name": "大阪大学SSO自動ログイン",
  "version": "1.0",
  "description": "大阪大学IT認証基盤サービスに自動ログインします。",
  "permissions": ["activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": ["https://ou-idp.auth.osaka-u.ac.jp/idp/sso_redirect*"], // ここが重要
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://ou-idp.auth.osaka-u.ac.jp/idp/authnPwd*"],
      "js": ["content_role_select.js"],
      "run_at": "document_idle"
    }
  ]
}